rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'tjuniemma@gmail.com'
      ); 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Profile Validation
    function isValidUserProfile(data) {
      return data.get('uid', '') is string && data.get('uid', '').size() <= 128
        && data.get('email', '') is string && data.get('email', '').size() <= 256
        && (data.get('displayName', '') is string || data.get('displayName', null) == null)
        && (data.get('photoURL', '') is string || data.get('photoURL', null) == null)
        && data.get('isVip', false) is bool
        && data.get('isAdmin', false) is bool
        && (data.get('createdAt', '') is string || data.get('createdAt', null) is timestamp);
    }

    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isSignedIn() && (uid == request.auth.uid)
        && isValidUserProfile(incoming())
        && (incoming().isAdmin == false || isAdmin())
        && (incoming().isVip == false || isAdmin());
        
      allow update: if (isOwner(uid) || isAdmin())
        && isValidUserProfile(incoming())
        && incoming().get('uid', '') == existing().get('uid', '')
        && incoming().get('email', '') == existing().get('email', '')
        && (isAdmin() || (incoming().get('isVip', false) == existing().get('isVip', false) && incoming().get('isAdmin', false) == existing().get('isAdmin', false)));
        
      match /activities/{activityId} {
        function isValidActivity(data) {
          return data.toolId is string && data.toolId.size() <= 100
            && data.toolName is string && data.toolName.size() <= 100
            && data.userId == request.auth.uid
            && data.timestamp is timestamp;
        }

        allow list: if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid) 
          && isValidActivity(incoming())
          && incoming().timestamp == request.time;
      }
    }

    // Collection Group Security for Admin Dashboard
    match /{path=**}/activities/{activityId} {
      allow list: if isAdmin();
    }

    match /ads/{adId} {
      function isValidAd(data) {
        return data.title is string && data.title.size() <= 200
          && data.imageUrl is string && data.imageUrl.size() <= 1000
          && data.targetUrl is string && data.targetUrl.size() <= 1000
          && data.placement in ['top', 'bottom', 'sidebar']
          && data.active is bool;
      }

      allow read: if true;
      allow write: if isAdmin() && isValidAd(incoming());
      allow delete: if isAdmin();
    }

    match /broadcasts/{broadcastId} {
      function isValidBroadcast(data) {
        return data.message is string && data.message.size() <= 1000
          && data.type in ['info', 'warning', 'critical', 'success']
          && data.active is bool
          && data.createdAt is timestamp;
      }

      allow read: if true;
      allow write: if isAdmin() && isValidBroadcast(incoming());
      allow delete: if isAdmin();
    }
  }
}
