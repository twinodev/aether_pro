rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() { 
      return isVerified() && (
        request.auth.token.email == 'tjuniemma@gmail.com'
      ); 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Profile Validation
    function isValidUserProfile(data) {
      return data.get('uid', '') is string && data.get('uid', '').size() <= 128
        && data.get('email', '') is string && data.get('email', '').size() <= 256
        && (data.get('displayName', '') is string || data.get('displayName', null) == null)
        && (data.get('photoURL', '') is string || data.get('photoURL', null) == null)
        && (data.get('business', null) == null || (
          data.business.get('name', '') is string &&
          (data.business.get('address', '') is string || !('address' in data.business)) &&
          (data.business.get('phone', '') is string || !('phone' in data.business)) &&
          (data.business.get('currency', 'KES') is string)
        ))
        && data.get('isVip', false) is bool
        && data.get('isAdmin', false) is bool
        && (data.get('createdAt', '') is string || data.get('createdAt', null) is timestamp);
    }

    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isVerified() && (uid == request.auth.uid)
        && isValidUserProfile(incoming())
        && (incoming().isAdmin == false || isAdmin())
        && (incoming().isVip == false || isAdmin());
        
      allow update: if (isVerified() && (uid == request.auth.uid) || isAdmin())
        && isValidUserProfile(incoming())
        && (isAdmin() || (
             incoming().get('uid', '') == existing().get('uid', '') &&
             incoming().get('email', '') == existing().get('email', '') &&
             incoming().get('isVip', false) == existing().get('isVip', false) &&
             incoming().get('isAdmin', false) == existing().get('isAdmin', false)
           ));
        
      match /activities/{activityId} {
        function isValidActivity(data) {
          return data.toolId is string && data.toolId.size() <= 100
            && data.toolName is string && data.toolName.size() <= 100
            && data.userId == request.auth.uid
            && data.timestamp is timestamp;
        }

        allow list: if isOwner(uid) || isAdmin();
        allow create: if isVerified() && (uid == request.auth.uid) 
          && isValidActivity(incoming())
          && incoming().timestamp == request.time;
      }
    }

    // Collection Group Security for Admin Dashboard
    match /{path=**}/activities/{activityId} {
      allow list: if isAdmin();
    }

    match /ads/{adId} {
      function isValidAd(data) {
        return data.title is string && data.title.size() <= 200
          && data.imageUrl is string && data.imageUrl.size() <= 1000
          && data.targetUrl is string && data.targetUrl.size() <= 1000
          && data.placement in ['top', 'bottom', 'sidebar']
          && data.active is bool;
      }

      allow read: if true;
      allow write: if isAdmin() && isValidAd(incoming());
      allow delete: if isAdmin();
    }

    match /broadcasts/{broadcastId} {
      function isValidBroadcast(data) {
        return data.message is string && data.message.size() <= 1000
          && data.type in ['info', 'warning', 'critical', 'success']
          && data.active is bool
          && data.createdAt is timestamp;
      }

      allow read: if true;
      allow write: if isAdmin() && isValidBroadcast(incoming());
      allow delete: if isAdmin();
    }

    // Duka Systems
    function isValidProduct(data) {
      return data.name is string && data.name.size() <= 200
        && data.sku is string && data.sku.size() <= 100
        && (data.category is string || data.category == null || !('category' in data))
        && (data.barcode is string || data.barcode == null || !('barcode' in data))
        && data.price is number
        && (data.cost is number || data.cost == null || !('cost' in data))
        && (data.unit is string || data.unit == null || !('unit' in data))
        && (data.imageUrl is string || data.imageUrl == null || !('imageUrl' in data))
        && (data.ownerId == request.auth.uid || isAdmin())
        && (data.createdAt is timestamp || data.createdAt == null || !('createdAt' in data));
    }

    function isValidLocation(data) {
      return data.name is string && data.name.size() <= 200
        && (data.address is string || data.address == null || !('address' in data))
        && (data.phone is string || data.phone == null || !('phone' in data))
        && data.ownerId == request.auth.uid;
    }

    function isValidInventoryItem(data) {
      return data.quantity is number
        && (data.minStockLevel is number || data.minStockLevel == null || !('minStockLevel' in data))
        && (data.lastRestockedAt is timestamp || data.lastRestockedAt == null || !('lastRestockedAt' in data))
        && (data.productId is string || !('productId' in data))
        && (data.locationId is string || !('locationId' in data));
    }

    function isValidSale(data) {
      return data.items is list
        && data.total is number
        && data.paymentMethod in ['mpesa', 'cash', 'credit']
        && data.locationId is string
        && data.userId == request.auth.uid
        && (data.timestamp is timestamp || data.timestamp == null || !('timestamp' in data));
    }

    function isValidMembership(data) {
      return data.userId is string
        && data.role in ['manager', 'cashier']
        && (data.email is string || !('email' in data))
        && (data.addedAt is timestamp || !('addedAt' in data));
    }

    function isValidScan(data) {
      return data.code is string && data.code.size() <= 256
        && data.locationId is string
        && (data.userId is string || !('userId' in data))
        && data.scannedAt is timestamp;
    }

    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isValidProduct(incoming()) && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin()) && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    match /locations/{locationId} {
      function isLocationOwner(locId) {
        return get(/databases/$(database)/documents/locations/$(locId)).data.ownerId == request.auth.uid;
      }
      function hasMembership(locId) {
        return exists(/databases/$(database)/documents/locations/$(locId)/memberships/$(request.auth.uid));
      }
      function getRole(locId) {
        return get(/databases/$(database)/documents/locations/$(locId)/memberships/$(request.auth.uid)).data.role;
      }

      allow get: if isVerified() && (resource.data.ownerId == request.auth.uid || hasMembership(locationId) || isAdmin());
      allow list: if isVerified(); // App filters by ownerId or membership
      allow create: if isVerified() && isValidLocation(incoming());
      allow update: if isVerified() && (resource.data.ownerId == request.auth.uid || isAdmin()) && isValidLocation(incoming());
      allow delete: if isAdmin();

      match /memberships/{userId} {
        allow read: if isVerified() && (isLocationOwner(locationId) || request.auth.uid == userId || isAdmin());
        allow write: if isVerified() && (isLocationOwner(locationId) || isAdmin()) && isValidMembership(incoming());
      }

      match /scans/{scanId} {
        allow get: if isVerified() && (isLocationOwner(locationId) || hasMembership(locationId) || isAdmin());
        allow create: if isVerified() && (isLocationOwner(locationId) || hasMembership(locationId) || isAdmin()) && isValidScan(incoming());
      }

      match /inventory/{productId} {
        allow read: if isVerified() && (isLocationOwner(locationId) || hasMembership(locationId) || isAdmin());
        allow write: if isVerified() && (isLocationOwner(locationId) || (hasMembership(locationId) && getRole(locationId) == 'manager') || isAdmin()) && isValidInventoryItem(incoming());
      }

      match /sales/{saleId} {
        allow read: if isVerified() && (isLocationOwner(locationId) || hasMembership(locationId) || isAdmin());
        allow create: if isVerified() && (isLocationOwner(locationId) || hasMembership(locationId)) && isValidSale(incoming());
      }
    }
  }
}
